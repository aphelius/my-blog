---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import WeatherWidget from "@/components/WeatherWidget.astro";
import WeatherEffect from "@/components/WeatherEffect.astro";
import Card from "@/components/Card.astro";
import LinkButton from "@/components/LinkButton.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { useTranslations } from "@/i18n";
import config from "@/config";

const { socials, posts: postsConfig } = config;

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

const posts = await getCollection("posts");
const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
const homePath = getRelativeLocaleUrl(locale, "");
---

<Layout>
  <WeatherEffect />
  <Header />
  <main
    id="main-content"
    data-layout="index"
    data-home-path={homePath}
    class="app-layout"
  >
    <section id="hero" class="border-border border-b pt-8 pb-6">
      <h1
        class="hero-title my-4 inline-block text-4xl font-bold sm:my-8 sm:text-5xl"
        data-typing={config.site.title}
      >
        {config.site.title}
      </h1>
      <a
        target="_blank"
        href={`${import.meta.env.BASE_URL.replace(/\/?$/, "/")}rss.xml`}
        class="inline-block"
        aria-label="RSS Feed"
        title="RSS Feed"
      >
        <IconRss
          width={20}
          height={20}
          class="stroke-accent scale-125 stroke-3 rtl:-rotate-90"
        />
        <span class="sr-only">RSS Feed</span>
      </a>

      <WeatherWidget />

      <p
        id="time-greeting"
        class="reveal text-accent mt-3 font-medium"
        hidden
      >
      </p>

      <p class="reveal mt-2">
        欢迎来到「盐究笔记」—— 一个磕盐人的技术自留地，记录学习、实践与那些值得写下来的踩坑。
      </p>
      <p class="reveal mt-2">
        你可以浏览下方的文章，或通过
        <LinkButton
          class="hover:text-accent underline decoration-dashed underline-offset-4"
          href={`${import.meta.env.BASE_URL.replace(/\/?$/, "/")}rss.xml`}
        >
          RSS
        </LinkButton> 订阅更新。
      </p>
      {
        socials.length > 0 && (
          <div class="mt-4 flex max-sm:flex-col sm:items-center">
            <div class="me-2 mb-1 whitespace-nowrap sm:mb-0">
              {t.home.socialLinks}:
            </div>
            <Socials />
          </div>
        )
      }
    </section>

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pt-12 pb-6",
            { "border-border border-b": recentPosts.length > 0 },
          ]}
        >
          <h2 class="reveal text-2xl font-semibold tracking-wide">
            {t.home.featured}
          </h2>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-12 pb-6">
          <h2 class="reveal text-2xl font-semibold tracking-wide">
            {t.home.recentPosts}
          </h2>
          <ul>
            {recentPosts.slice(0, postsConfig.perIndex).map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href={getRelativeLocaleUrl(locale, "posts")}>
        {t.home.allPosts}
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  // 按访客本地时间切换欢迎语
  function updateGreeting() {
    const el = document.getElementById("time-greeting");
    if (!el) return;
    const h = new Date().getHours();
    let text: string;
    if (h >= 5 && h < 11) text = "早上好 ☀️ 新的一天，元气满满～";
    else if (h >= 11 && h < 13) text = "中午好 🍱 记得好好吃饭。";
    else if (h >= 13 && h < 18) text = "下午好 ☕ 来杯咖啡继续战斗。";
    else if (h >= 18 && h < 23) text = "晚上好 🌆 辛苦一天啦。";
    else text = "夜深了 🌙 别熬太晚，早点休息。";
    el.textContent = text;
    el.removeAttribute("hidden");
  }

  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset;
    const baseRoot = import.meta.env.BASE_URL.replace(/\/?$/, "/");
    if (indexLayout?.layout) {
      sessionStorage.setItem("backUrl", indexLayout.homePath ?? baseRoot);
    }
    updateGreeting();
  });
</script>
