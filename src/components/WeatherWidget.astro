---
// 首页实时天气（混合定位）：
//   默认走 /api/weather 的 IP 定位（城市级，可能落到省会）；
//   点 📍 按钮触发浏览器精确定位（需授权），用更准的经纬度重新拉取。
//   若此前已授权，再次进入会自动用精确定位（不再弹窗）。
// 本地 dev 无 Functions 会优雅隐藏；纯文本无动画，不受 prefers-reduced-motion 影响。
---

<span
  id="weather-widget"
  class="text-muted-foreground mt-3 hidden items-center gap-1 text-sm"
  aria-live="polite"
>
  <span id="weather-text"></span>
  <button
    id="weather-locate"
    type="button"
    title="使用精确定位"
    aria-label="使用精确定位"
    class="hover:text-accent ml-1 hidden rounded px-1 transition-colors"
  >
    📍
  </button>
</span>

<script>
  // WMO weather_code -> emoji + 中文描述
  const WMO: Record<number, [string, string]> = {
    0: ["☀️", "晴"],
    1: ["🌤️", "大致晴朗"],
    2: ["⛅", "多云"],
    3: ["☁️", "阴"],
    45: ["🌫️", "雾"],
    48: ["🌫️", "雾凇"],
    51: ["🌦️", "小毛毛雨"],
    53: ["🌦️", "毛毛雨"],
    55: ["🌧️", "大毛毛雨"],
    61: ["🌦️", "小雨"],
    63: ["🌧️", "中雨"],
    65: ["🌧️", "大雨"],
    66: ["🌧️", "冻雨"],
    67: ["🌧️", "强冻雨"],
    71: ["🌨️", "小雪"],
    73: ["🌨️", "中雪"],
    75: ["❄️", "大雪"],
    77: ["❄️", "雪粒"],
    80: ["🌦️", "阵雨"],
    81: ["🌧️", "强阵雨"],
    82: ["⛈️", "暴雨"],
    85: ["🌨️", "阵雪"],
    86: ["❄️", "强阵雪"],
    95: ["⛈️", "雷阵雨"],
    96: ["⛈️", "雷阵雨伴冰雹"],
    99: ["⛈️", "强雷暴伴冰雹"],
  };

  const CACHE_KEY = "weather:v1";
  const PRECISE_KEY = "weather:precise"; // localStorage：用户已选精确定位
  const TTL = 30 * 60 * 1000; // 30 分钟

  type Weather = {
    city: string;
    temperature: number | null;
    code: number | null;
    isDay: boolean;
  };

  const base = () => import.meta.env.BASE_URL.replace(/\/?$/, "/");

  function render(w: Weather) {
    // 广播给天气特效层（首页背景），即便不显示气温也通知
    window.dispatchEvent(new CustomEvent("weather:update", { detail: w }));
    const wrap = document.getElementById("weather-widget");
    const text = document.getElementById("weather-text");
    const btn = document.getElementById("weather-locate");
    if (!wrap || !text) return;
    if (w.temperature == null) return;
    const [emoji, desc] = WMO[w.code ?? -1] ?? ["🌡️", ""];
    const place = w.city ? `${w.city} ` : "";
    text.textContent = `${emoji} ${place}${w.temperature}°C ${desc}`.trim();
    wrap.classList.remove("hidden");
    wrap.classList.add("flex");
    // 支持地理定位才显示 📍 按钮
    if (btn && "geolocation" in navigator) btn.classList.remove("hidden");
  }

  function cache(w: Weather) {
    try {
      sessionStorage.setItem(CACHE_KEY, JSON.stringify({ t: Date.now(), w }));
    } catch {
      /* ignore */
    }
  }

  // 反向地理编码：把经纬度换成城市名（Nominatim / OSM，免费、支持 CORS）。
  // 国内用简体中文名（accept-language=zh-CN），国外用英文名。先取 zh-CN
  // （多数访客在国内，省一次请求），若国家非 CN 则再取一次 en。
  type NomResp = {
    address?: {
      city?: string;
      town?: string;
      county?: string;
      municipality?: string;
      state?: string;
      country_code?: string;
    };
  };
  async function reverseCity(lat: number, lon: number): Promise<string> {
    const get = async (lang: string): Promise<NomResp | null> => {
      try {
        const r = await fetch(
          `https://nominatim.openstreetmap.org/reverse?format=jsonv2` +
            `&addressdetails=1&lat=${lat}&lon=${lon}&accept-language=${lang}`
        );
        return r.ok ? ((await r.json()) as NomResp) : null;
      } catch {
        return null;
      }
    };
    const pick = (d: NomResp) => {
      const a = d.address ?? {};
      return a.city || a.town || a.county || a.municipality || a.state || "";
    };

    const zh = await get("zh-CN");
    if (!zh) return "";
    if (zh.address?.country_code === "cn") return pick(zh);
    const en = await get("en");
    return pick(en ?? zh);
  }

  async function fetchWeather(query = ""): Promise<Weather | null> {
    try {
      const res = await fetch(`${base()}api/weather${query}`);
      if (!res.ok) return null;
      const w = (await res.json()) as Weather;
      return w.temperature == null ? null : w;
    } catch {
      return null;
    }
  }

  // 用浏览器精确定位刷新天气
  function locatePrecise(viaButton: boolean) {
    if (!("geolocation" in navigator)) return;
    const btn = document.getElementById("weather-locate");
    if (btn && viaButton) btn.textContent = "⏳";
    navigator.geolocation.getCurrentPosition(
      async pos => {
        const { latitude, longitude } = pos.coords;
        const city = await reverseCity(latitude, longitude);
        const q =
          `?lat=${latitude.toFixed(4)}&lon=${longitude.toFixed(4)}` +
          (city ? `&city=${encodeURIComponent(city)}` : "");
        const w = await fetchWeather(q);
        if (btn) btn.textContent = "📍";
        if (!w) return;
        // 客户端有更准的城市名时优先用它
        if (city) w.city = city;
        render(w);
        cache(w);
        try {
          localStorage.setItem(PRECISE_KEY, "1");
        } catch {
          /* ignore */
        }
      },
      () => {
        // 用户拒绝 / 超时：保持 IP 结果，清除自动精确标记
        if (btn) btn.textContent = "📍";
        try {
          localStorage.removeItem(PRECISE_KEY);
        } catch {
          /* ignore */
        }
      },
      { enableHighAccuracy: true, timeout: 8000, maximumAge: 10 * 60 * 1000 }
    );
  }

  async function maybeAutoPrecise(): Promise<boolean> {
    let optedIn = false;
    try {
      optedIn = localStorage.getItem(PRECISE_KEY) === "1";
    } catch {
      /* ignore */
    }
    if (!optedIn || !("permissions" in navigator)) return false;
    try {
      const status = await navigator.permissions.query({
        name: "geolocation" as PermissionName,
      });
      if (status.state === "granted") {
        locatePrecise(false); // 已授权：静默精确定位，不弹窗
        return true;
      }
    } catch {
      /* ignore */
    }
    return false;
  }

  async function initWeather() {
    const el = document.getElementById("weather-widget");
    if (!el) return;

    // 绑定 📍 按钮
    const btn = document.getElementById("weather-locate");
    btn?.addEventListener("click", () => locatePrecise(true));

    // 会话内缓存，避免重复请求
    try {
      const raw = sessionStorage.getItem(CACHE_KEY);
      if (raw) {
        const { t, w } = JSON.parse(raw);
        if (Date.now() - t < TTL) {
          render(w);
          // 缓存命中后仍尝试静默精确化（若已授权）
          maybeAutoPrecise();
          return;
        }
      }
    } catch {
      /* ignore */
    }

    // 先尝试静默精确定位；否则回退 IP
    const auto = await maybeAutoPrecise();
    if (auto) return;

    const w = await fetchWeather();
    if (!w) return; // 本地 dev / 接口异常：静默隐藏
    render(w);
    cache(w);
  }

  document.addEventListener("astro:page-load", initWeather);
</script>
